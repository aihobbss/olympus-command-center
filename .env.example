# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# Shopify — per-store credentials stored in Supabase oauth_tokens table
# (each user creates their own Shopify app, no app-level keys needed)

# Facebook/Meta — app-level (one FB app for the platform)
# Per-user OAuth tokens stored in Supabase oauth_tokens table
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Nanobanana Pro — app-level
NANOBANANA_API_KEY=your-nanobanana-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENCRYPTION_KEY=generate-a-random-32-byte-hex-string
